# release_notes.sh 可选配置
#
# 当前脚本仅保留 Codex 命令可配置，其他参数已固定在脚本中。
# 需要的 Codex CLI 能力：
# 1. 新版支持: codex exec -C <repo> -o <file> <prompt>
# 2. 或旧版支持: codex --input <prompt> --output <file>

RELEASE_NOTES_CODEX_BIN='codex'

# 飞书机器人推送配置
# 配置 FEISHU_WEBHOOK_URL 后，release_notes.sh 会在生成每个模块的摘要后自动推送。
# 如果机器人启用了签名校验，再额外配置 FEISHU_SECRET。
FEISHU_WEBHOOK_URL='https://open.feishu.cn/open-apis/bot/v2/hook/8ff286bf-de3e-4117-8029-3d983b621402'
FEISHU_SECRET=''
FEISHU_MESSAGE_PREFIX='[变更通知]'
